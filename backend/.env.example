# Groq API Key - Get from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ChromaDB persistent storage path
CHROMA_DB_PATH=./vectordb

# Embedding model (BAAI/bge-small-en-v1.5 recommended)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Groq Model — all options below are FREE on Groq's free tier (rate-limited, no card needed)
# llama-3.3-70b-versatile      -> current default. Solid, well-tested, 1K req/day free.
# openai/gpt-oss-120b          -> newer, generally better instruction-following & reasoning. Same free-tier RPD. Worth A/B testing for this use case.
# meta-llama/llama-4-scout-17b-16e-instruct -> fastest/cheapest, weaker reasoning, still "preview" status (can be deprecated without much notice)
GROQ_MODEL=llama-3.3-70b-versatile

# Upload directory
UPLOAD_DIR=./uploads
